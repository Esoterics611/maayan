# Copy to .env on the VPS and fill in. NEVER commit the real .env.

# --- Domain (point maavar.* and maayan.* A-records at the VPS IP) ---
ROOT_DOMAIN=example.co.il

# --- Postgres (self-hosted in Docker) ---
POSTGRES_USER=academy
POSTGRES_PASSWORD=change-me-long-random

# --- Auth.js ---
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxx

# --- Cardcom (recurring memberships, ILS, installments, Israeli invoices) ---
CARDCOM_TERMINAL=1000
CARDCOM_API_NAME=xxx
CARDCOM_API_PASSWORD=xxx
# Shared secret you set; used to verify webhook authenticity (see cardcom-webhook.ts)
CARDCOM_WEBHOOK_SECRET=change-me-long-random

# --- Optional: prebuilt image refs (CI) instead of building on the box ---
# MAAVAR_IMAGE=ghcr.io/you/maavar:latest
# MAAYAN_IMAGE=ghcr.io/you/maayan:latest
