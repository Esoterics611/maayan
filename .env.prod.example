# Production env for maayan (docker-compose.prod.yml). Copy to `.env` ON THE VM and fill in.
# NEVER commit .env. Secrets are read from env only. See docs/cloud_deploy/01_MANUAL_SETUP.md.

# ---- Generation (cloud, OpenRouter) ----------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# ---- Auth / multi-user (PUBLIC deploy → ON) --------------------------------
AUTH_ENABLED=true
# Cookies sent over HTTPS only. Tailscale Funnel terminates TLS, so keep this true.
# (If you ever test over plain http://<tailnet-ip>:8000, set this false or login won't stick.)
AUTH_COOKIE_SECURE=true
# First admin, seeded ONCE on first boot. Log in, create your real users, rotate this
# password, then you can blank these two.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=

# ---- Embeddings (CPU on the free tier; no GPU) -----------------------------
EMBED_DEVICE=cpu

# ---- Corpus / retrieval (tune via the eval harness) ------------------------
BOOKS=["Tanya","Likutei Torah","Torah Or"]
SCORE_THRESHOLD=0.45

# NOTE: QDRANT_URL, UI_HOST, UI_PORT are set by docker-compose.prod.yml — don't set them here.
