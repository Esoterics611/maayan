# Copy to .env and fill in. NEVER commit .env. Secrets are read from env only.

# ---- Generation (cloud, OpenRouter) ----------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pick an open model; test 2-3 for Hebrew quality (Qwen / Llama / DeepSeek).
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Generation backend: "openrouter" (default) or "ollama" (Prompt 8, local).
GENERATION_BACKEND=openrouter
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# ---- Vector DB (local Qdrant) ----------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=maayan

# ---- Embeddings (local) ----------------------------------------------------
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
EMBED_DEVICE=auto

# ---- Reranker (local, optional) --------------------------------------------
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ---- Retrieval -------------------------------------------------------------
# SCORE_THRESHOLD gates default-deny: min top relevance (dense-cosine, or reranker
# score when RERANK_ENABLED) required to answer. Tune per corpus via the eval harness.
TOP_K=8
SCORE_THRESHOLD=0.45
EXPERT_BOOST=1.0

# ---- Query expansion (Prompt 31a; off by default) --------------------------
# When on, the query is expanded into several retrieval queries (lexicon vocab +
# optional LLM reformulations/HyDE) and the hits are RRF-fused. Additive only — the
# default-deny gate is unchanged. Measure the lift with `make eval-expand`.
QUERY_EXPAND_ENABLED=false
QUERY_EXPAND_LEXICON=true
QUERY_EXPAND_HYDE=true
QUERY_EXPAND_VARIANTS=3
QUERY_EXPAND_MAX_QUERIES=6

# ---- Reasoning & synthesis (Prompt 31b; off by default) --------------------
# RAG_REASONING_ENABLED: `ask` runs two stages — analyze the sources into a study
# map, then synthesize a single woven, cited answer. ANSWER_VERIFY_ENABLED: after
# answering, flag sentences not supported by their cited sources.
RAG_REASONING_ENABLED=false
ANSWER_VERIFY_ENABLED=false

# ---- Corpus ----------------------------------------------------------------
# JSON array; the works to ingest from Sefaria.
BOOKS=["Tanya","Likutei Torah","Torah Or"]

# ---- Storage ---------------------------------------------------------------
DB_PATH=data/maayan.sqlite3
